# Variable Declarations
a = 10
b = 3.14
name = "Pulse"
is_active = true
tensor1 = @[1, 2, 3, 4, 5]
tensor2 = @[[1, 2, 3], [4, 5, 6]]

print(type(tensor2))

# Reassignment
a = 20
b = b + 1.0
name = "Pulse Language"
is_active = false

print(type(a))
print(type(name))

# Null / None
data1 = null
data2 = None

print(type(data1))