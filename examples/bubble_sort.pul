def bubble_sort(arr):
    n = len(arr)

    i = 0
    while i < n:
        j = 0
        while j < n - i - 1:
            if arr[j] > arr[j + 1]:
                temp = arr[j]
                arr[j] = arr[j+1]
                arr[j+1] = temp
            j = j + 1
        i = i + 1
    
    return arr

nums = [5, 2, 9, 1, 5, 6]
print("Sorted:", bubble_sort(nums))