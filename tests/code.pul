print(2 + 3 * 4)
print(20 - 5 - 3)
print(20 / 5 / 2)
print(-2 * 3)
print(2 + 3 > 4)
print(2 * 3 == 6)
print(True or False and False)
print(not False and False)
print(3 in [1, 2, 3] and True)

a = @[[1, 2], [3, 4]]
b = @[[5, 6], [7, 8]]
c = @[[1, 0], [0, 1]]

print(a + b @ c)

def square(x):
    return x * x
print(2 + 3 |> square)

nums = [10, 20, 30]
print(nums[1] + 5)

print(10 - 3 - 2)
print(100 / 10 / 2)
print(True and True and False)
print(False or False or True)