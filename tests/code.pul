# sum, any, all
nums = [1, 2, 3, 4, 5]
print(sum(nums))          # 15
print(sum(nums, 10))      # 25
print(any([False, True, False]))  # true
print(all([True, True, True]))    # true
print(all([True, False, True]))   # false

# multi-line strings
text = """
Hello
World
"""
print(text)

# list extend and count
a = [1, 2, 3]
a.extend([4, 5, 6])
print(a)               # [1, 2, 3, 4, 5, 6]
a.extend(range(7, 10))
print(a)               # [1, 2, 3, 4, 5, 6, 7, 8, 9]
print(a.count(1))      # 1

# string format
print("Hello, {}!".format("Daud"))         # Hello, Daud!
print("{} + {} = {}".format(1, 2, 3))      # 1 + 2 = 3