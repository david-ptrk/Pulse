import random

# core
print(random.random())           # 0.374...
print(random.randint(1, 10))     # 7
print(random.uniform(1.0, 5.0)) # 3.14...
print(random.randrange(0, 100, 5)) # 45

# sequences
nums = [1, 2, 3, 4, 5]
print(random.choice(nums))          # 3
print(random.choices(nums, k=3))    # [2, 2, 5]
print(random.sample(nums, k=3))     # [4, 1, 3]
random.shuffle(nums)
print(nums)                          # [3, 1, 5, 2, 4]

# distributions
print(random.gauss(0.0, 1.0))        # -0.31...
print(random.normalvariate(0.0, 1.0)) # 0.87...
print(random.expovariate(1.5))        # 0.42...
print(random.triangular(0.0, 10.0, 5.0)) # 4.91...

# reproducibility
random.seed(42)
print(random.randint(1, 100))   # always same value
random.seed("pulse")
print(random.random())          # always same value