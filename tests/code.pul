# literal matching
status = 404
match status:
    case 200:
        print("OK")
    case 404:
        print("Not Found")
    case 500:
        print("Server Error")
    case _:
        print("Unknown")

# capture variable
match status:
    case 200:
        print("OK")
    case code:
        print(f"Got code: {code}")

# OR pattern
match status:
    case 400 | 401 | 403:
        print("Client Error")
    case 500 | 502 | 503:
        print("Server Error")

# guard condition
x = 42
match x:
    case n if n < 0:
        print("negative")
    case n if n == 0:
        print("zero")
    case n:
        print(f"positive: {n}")

# sequence pattern
point = [1, 2]
match point:
    case [0, 0]:
        print("origin")
    case [x, 0]:
        print(f"on x-axis at {x}")
    case [0, y]:
        print(f"on y-axis at {y}")
    case [x, y]:
        print(f"point at {x}, {y}")

# mapping pattern
response = {"status": 200, "body": "hello"}
match response:
    case {"status": 200, "body": msg}:
        print(f"Success: {msg}")
    case {"status": 404}:
        print("Not found")
    case _:
        print("Unknown response")