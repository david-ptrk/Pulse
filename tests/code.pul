# ternary
x = 10
label = "big" if x > 5 else "small"
print(label)   # big

age = 20
status = "adult" if age >= 18 else "minor"
print(status)  # adult

# chained comparisons
x = 5
print(0 < x < 10)    # true
print(0 < x < 4)     # false
print(1 <= x <= 5)   # true
print(10 > x > 3)    # true

# is / is not
print(null is null)      # true
print(True is True)      # true
print(True is False)     # false

a = [1, 2, 3]
b = a
c = [1, 2, 3]
print(a is b)       # true  — same object
print(a is c)       # false — different objects
print(a is not c)   # true