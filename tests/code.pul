# list comprehension
nums = [1, -2, 3, -4, 5]
pos = [x * 2 for x in nums if x > 0]
print(pos)   # [2, 6, 10]

squares = [x * x for x in range(1, 6)]
print(squares)  # [1, 4, 9, 16, 25]

# *args
def sum_all(*args):
    total = 0
    for n in args:
        total += n
    return total

print(sum_all(1, 2, 3, 4, 5))  # 15

def first_and_rest(first, *rest):
    print(first)
    print(rest)

first_and_rest(1, 2, 3, 4)  # 1 then [2, 3, 4]

# list methods
nums = [3, 1, 4, 1, 5]
print(nums.index(4))       # 2
print(nums.find(99))       # -1
nums.insert(0, 99)
print(nums)                # [99, 3, 1, 4, 1, 5]