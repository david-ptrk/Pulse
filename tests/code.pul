from models import LogisticRegression

model = LogisticRegression()
print(model)
data = @[[1, 2], [3, 4], [5, 6], [7, 8]]
labels = @[0, 0, 1, 1]

model.train(data, labels)

predictions = model.predict(data)
print(predictions)

accuracy = model.score(data, labels)
print(accuracy)

print(model.is_trained())
print(model)