class Person:
    def __init__(self, name, age):
        self.name = name
        self.age = age
    
    def __str__(self):
        return f"Person({self.name}, {self.age})"

p = Person("Pulse", 1)
print(p)               # Person(Pulse, 1)
print(p.name)          # Pulse
print(p.age)           # 1

p.age = 2
print(p.age)           # 2

class Animal:
    def __init__(self, species):
        self.species = species

a = Animal("cat")
print(a)               # <instance of Animal>  (no __str__, falls back to default)
print(a.species)       # cat